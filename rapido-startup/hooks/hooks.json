{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__stripe__.*write.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/garde-stripe-write.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/garde-calcul-script.py"
          }
        ]
      }
    ]
  }
}
