{
  "mcpServers": {
    "ElevenLabs": {
      "command": "uvx",
      "args": ["elevenlabs-mcp"],
      "env": {
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}",
        "ELEVENLABS_MCP_BASE_PATH": "${ELEVENLABS_MCP_BASE_PATH}"
      }
    },
    "rapidocms": {
      "type": "http",
      "url": "https://cms.rapidosoftware.com/mcp"
    }
  }
}
